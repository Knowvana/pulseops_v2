{
  "enabled": false,
  "storage": "database",
  "database": {
    "logsTable": "system_logs",
    "retentionDays": 90,
    "batchInsertSize": 50
  },
  "levels": ["debug", "info", "warn", "error"],
  "defaultLevel": "info",
  "captureOptions": {
    "uiLogs": true,
    "apiLogs": true,
    "consoleLogs": true,
    "moduleLogs": true
  },
  "management": {
    "maxUiEntries": 1000,
    "maxApiEntries": 500,
    "pushIntervalMs": 30000,
    "notifyDebounceMs": 250,
    "maxBodyBytes": 10000
  }
}
