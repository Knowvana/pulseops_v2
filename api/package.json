{
  "name": "pulseops-v2-api",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#config/*": "./src/config/*",
    "#config": "./src/config/index.js",
    "#shared/*": "./src/shared/*",
    "#core/*": "./src/core/*",
    "#root/*": "./src/*",
    "#apiRoot/*": "./*"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "dev:watch": "node --watch-path=src --watch-preserve-output src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.19.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
